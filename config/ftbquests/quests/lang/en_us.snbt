	task.379D618C63FCB21E.title: "Colonies when ready"
	task.4A1968E2672037D7.title: "Noted the tech landscape"
	task.5B29CC214F154EBA.title: "Economy & metals"
	task.5CEA2D250E555976.title: "Used JEI & Jade"
	task.7257EC892AF4362C.title: "Ready to explore Apotheosis"
}
