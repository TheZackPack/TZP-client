		{
			dependencies: ["t100000000000011"]
			description: [
				"The Chemical Dissolution Chamber dissolves ores into chemical slurries, the first step toward 5x ore processing. This is Mekanism's legendary endgame ore chain."
				""
				"The full 5x chain is: Dissolution Chamber, Washer, Crystallizer, Injection Chamber, and Purification Chamber. In TZP, supremium is needed via a custom KubeJS recipe. Worth the grind."
			]
			icon: "mekanism:chemical_dissolution_chamber"
