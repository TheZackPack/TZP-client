			title: "Basic Energy Cube"
			x: -6.0d
			y: -6.5d
		}
		{
			dependencies: ["t10000000000000d"]
			description: [
				"Universal Cables transfer FE between generators, machines, and energy storage. They auto-connect to any FE-compatible block from any mod."
				""
				"Right-click with a Configurator to change cable modes. Basic cables handle moderate throughput — upgrade to Advanced or Elite for high-power setups."
			]
			icon: "mekanism:basic_universal_cable"
			id: "t10000000000000e"
			rewards: [{
				id: "t1r000000000000e"
				type: "xp"
