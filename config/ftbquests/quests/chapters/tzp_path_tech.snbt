			y: -11.0d
		}
		{
			dependencies: ["t100000000000010"]
			description: [
				"The Digital Miner teleports ores directly from the ground into its inventory. Configure filters to target specific ores and set a mining radius."
				""
				"It replaces silk-touch mining runs entirely. Pair with an Enrichment Chamber to double everything it pulls up. Needs significant FE to run."
			]
