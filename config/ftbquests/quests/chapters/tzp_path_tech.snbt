			y: -8.0d
		}
		{
			dependencies: ["t10000000000000e"]
			description: [
				"Logistical Transporters are Mekanism's item pipes. They move items between inventories and can be color-coded and filtered for sorting."
				""
				"Use a Configurator to set sides to pull or push. Combine with Logistical Sorters for advanced item routing. These scale well into late game."
			]
			icon: "mekanism:basic_logistical_transporter"
			id: "t10000000000000f"
			rewards: [{
