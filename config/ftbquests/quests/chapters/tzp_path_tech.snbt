			x: -6.0d
			y: -9.5d
		}
		{
			dependencies: ["t10000000000000f"]
			description: [
				"The Basic Enriching Factory processes three items simultaneously in a single machine. It is a direct upgrade to the Enrichment Chamber."
				""
				"Factories come in Basic (3 slots), Advanced (5), and Elite (7) tiers. Upgrade them with tier installers. This is where Mekanism's throughput really takes off."
			]
			icon: "mekanism:basic_enriching_factory"
			id: "t100000000000010"
			rewards: [{
				id: "t1r0000000000010"
