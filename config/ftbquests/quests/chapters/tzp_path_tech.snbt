		{
			dependencies: ["t100000000000001"]
			description: [
				"Certus Quartz is the foundation of Applied Energistics 2. Mine it underground — it looks like a pale crystal embedded in stone."
				""
				"You can grow more Certus by placing Certus Quartz Seeds in water. You'll need a lot of it, so start a small farm early. Check JEI for seed crafting."
			]
			icon: "ae2:certus_quartz_crystal"
