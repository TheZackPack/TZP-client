				type: "item"
			}]
			title: "Cart Assembler"
			x: -9.0d
			y: -12.5d
		}
		{
			dependencies: ["t100000000000001"]
			description: [
				"The Heat Generator is Mekanism's starter power source. It burns coal, wood, or any furnace fuel — or place it on lava for passive heat-based FE generation."
				""
				"Lava mode is slower but free and infinite. This generator bridges you to Mekanism's machine ecosystem, which runs on Forge Energy (FE)."
			]
			icon: "mekanism:heat_generator"
			id: "t10000000000000a"
			rewards: [{
				id: "t1r000000000000a"
				type: "xp"
				xp: 30
			}]
			tasks: [{
				id: "t1t000000000000a"
				item: "mekanism:heat_generator"
				type: "item"
			}]
			title: "Heat Generator"
			x: -6.0d
			y: -2.0d
		}
		{
			dependencies: ["t10000000000000a"]
			description: [
				"The Metallurgic Infuser combines materials with an infuse type (carbon, redstone, diamond, etc.) to create advanced materials. Its most important recipe is Steel."
				""
				"To make Steel: infuse Iron Ingots with carbon (from coal or charcoal). Steel is used in almost every Mekanism machine, so automate this early."
			]
			icon: "mekanism:metallurgic_infuser"
			id: "t10000000000000b"
			rewards: [{
				id: "t1r000000000000b"
				type: "xp"
				xp: 35
			}]
			tasks: [{
				id: "t1t000000000000b"
				item: "mekanism:metallurgic_infuser"
				type: "item"
			}]
			title: "Metallurgic Infuser"
			x: -6.0d
			y: -3.5d
		}
		{
			dependencies: ["t10000000000000b"]
			description: [
				"The Enrichment Chamber doubles your raw ores into two dust per ore, which smelt into two ingots. This is Mekanism's bread-and-butter ore doubling."
				""
				"It also enriches other materials — redstone ore into enriched redstone, diamond ore into two diamonds, and more. A must-have machine from early to late game."
			]
			icon: "mekanism:enrichment_chamber"
			id: "t10000000000000c"
			rewards: [{
				id: "t1r000000000000c"
				type: "xp"
				xp: 35
			}]
			tasks: [{
				id: "t1t000000000000c"
				item: "mekanism:enrichment_chamber"
				type: "item"
			}]
			title: "Enrichment Chamber"
			x: -6.0d
			y: -5.0d
		}
		{
			dependencies: ["t10000000000000c"]
			description: [
				"The Basic Energy Cube stores Forge Energy (FE) and can charge items in its inventory. Think of it as a battery for your Mekanism setup."
				""
				"Upgrade to Advanced, Elite, and Ultimate tiers as your power needs grow. Place between generators and machines to buffer energy during demand spikes."
			]
			icon: "mekanism:basic_energy_cube"
			id: "t10000000000000d"
			rewards: [{
				id: "t1r000000000000d"
				type: "xp"
				xp: 30
