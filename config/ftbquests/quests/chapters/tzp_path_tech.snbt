	quests: [
		{
			dependencies: ["e7a2c91d4b0f56e8"]
			description: [
				"TZP has over a dozen tech mods covering power generation, ore processing, digital storage, logistics, and automation."
				""
				"Each branch below introduces a major mod — you don't need to do them all, but exploring multiple paths unlocks powerful cross-mod synergies. JEI (press R on items) is your best friend for finding recipes across mods."
				""
				"Pick a branch that sounds fun and dive in. You can always come back to try others later."
			]
			icon: "create:wrench"
			id: "t100000000000001"
			rewards: [{
				id: "t1r0000000000001"
				type: "xp"
				xp: 20
			}]
			shape: "gear"
			size: 1.5d
			tasks: [{
				id: "t1t0000000000001"
				title: "Open JEI and search for a mod item"
				type: "checkmark"
			}]
			title: "Welcome to Tech"
			x: 0.0d
			y: 0.0d
		}
		{
			dependencies: ["t100000000000001"]
			description: [
				"Create uses rotational power instead of electricity. The Hand Crank is the simplest way to generate Stress Units (SU) — right-click it to spin connected shafts."
				""
				"It won't power much, but it teaches the core concept: every Create machine needs rotation delivered via shafts and cogwheels. Think of SU like a power budget."
			]
			icon: "create:hand_crank"
			id: "t100000000000002"
			rewards: [{
				id: "t1r0000000000002"
				type: "xp"
				xp: 30
			}]
			tasks: [{
				id: "t1t0000000000002"
				item: "create:hand_crank"
				type: "item"
			}]
			title: "Hand Crank"
			x: -9.0d
			y: -2.0d
		}
		{
			dependencies: ["t100000000000002"]
			description: [
				"The Water Wheel is your first real hands-free power source. Place it on a shaft next to flowing water — the more water blocks touching it, the more SU it generates."
				""
				"A single wheel with good flow gives 256 SU, enough to run several early machines. Build a river dam or pour water from above for best results."
			]
			icon: "create:water_wheel"
			id: "t100000000000003"
			rewards: [{
				id: "t1r0000000000003"
				type: "xp"
				xp: 30
			}]
			tasks: [{
				id: "t1t0000000000003"
				item: "create:water_wheel"
				type: "item"
			}]
			title: "Water Wheel"
			x: -9.0d
			y: -3.5d
		}
		{
			dependencies: ["t100000000000003"]
			description: [
				"The Mechanical Press and Basin are Create's core crafting duo. Place a Basin under a Press on a shaft — the Press stamps items in the Basin into sheets, alloys, and more."
				""
				"Check JEI for Basin + Press recipes. You'll use this combo constantly for making Brass, sheets for casings, and dozens of other materials."
			]
			icon: "create:mechanical_press"
			id: "t100000000000004"
			rewards: [{
				id: "t1r0000000000004"
				type: "xp"
				xp: 35
			}]
			tasks: [{
				id: "t1t0000000000004"
				item: "create:mechanical_press"
				type: "item"
			}]
			title: "Mechanical Press & Basin"
			x: -9.0d
			y: -5.0d
		}
		{
			dependencies: ["t100000000000004"]
			description: [
				"The Millstone crushes ores and materials when given rotational power. Feed it raw ores to get double the output compared to a furnace."
				""
				"It is slower than the Crushing Wheels but much cheaper to build. Great early-game ore doubling before you move to Mekanism's Enrichment Chamber."
			]
			icon: "create:millstone"
			id: "t100000000000005"
			rewards: [{
				id: "t1r0000000000005"
				type: "xp"
				xp: 30
			}]
			tasks: [{
				id: "t1t0000000000005"
				item: "create:millstone"
				type: "item"
			}]
			title: "Millstone"
			x: -9.0d
			y: -6.5d
		}
		{
			dependencies: ["t100000000000005"]
			description: [
				"The Deployer simulates a player's hand. It can right-click, left-click, and use held items — making it essential for recipes that require manual interaction."
				""
				"Many Create recipes need a Deployer to apply items to things on belts or in the world. It is also key for Sequenced Assembly, Create's advanced crafting system."
			]
			icon: "create:deployer"
			id: "t100000000000006"
			rewards: [{
				id: "t1r0000000000006"
				type: "xp"
				xp: 40
			}]
			tasks: [{
				id: "t1t0000000000006"
				item: "create:deployer"
				type: "item"
			}]
			title: "Deployer"
			x: -9.0d
			y: -8.0d
		}
		{
			dependencies: ["t100000000000006"]
			description: [
				"The Mechanical Arm picks up items from one location and places them in another. You can configure multiple input and output points by right-clicking."
				""
				"Unlike belts, arms can reach across gaps and target specific inventories. Perfect for feeding multiple machines from a central chest or sorting outputs."
			]
			icon: "create:mechanical_arm"
			id: "t100000000000007"
			rewards: [{
				id: "t1r0000000000007"
				type: "xp"
				xp: 40
			}]
			tasks: [{
				id: "t1t0000000000007"
				item: "create:mechanical_arm"
				type: "item"
			}]
			title: "Mechanical Arm"
			x: -9.0d
			y: -9.5d
		}
		{
			dependencies: ["t100000000000007"]
			description: [
				"Mechanical Belts are Create's main item transport. Craft a Belt Connector with leather, then right-click two shafts to link them. Add Funnels to insert or extract items from adjacent inventories."
				""
				"Belts plus Funnels replace basic hoppers and are much faster. They form the backbone of any serious Create factory."
			]
			icon: "create:belt_connector"
			id: "t100000000000008"
			rewards: [{
				id: "t1r0000000000008"
				type: "xp"
				xp: 35
			}]
			tasks: [{
				id: "t1t0000000000008"
				item: "create:belt_connector"
				type: "item"
			}]
			title: "Belt & Funnel"
			x: -9.0d
			y: -11.0d
		}
		{
			dependencies: ["t100000000000008"]
			description: [
				"The Cart Assembler glues blocks onto a Minecart to create moving contraptions. Place it on rails, put your structure on top, and power with redstone."
				""
				"This unlocks flying machines, mobile drills, portable farms, and more. Combine with Mechanical Bearings and Rope Pulleys for even crazier builds."
			]
			icon: "create:cart_assembler"
			id: "t100000000000009"
			rewards: [{
				id: "t1r0000000000009"
				type: "xp"
				xp: 50
			}]
